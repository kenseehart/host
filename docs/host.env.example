# Host MCP environment — copy to ~/.config/ken/host/host.env

# GCP gateway (production)
HOST_MCP_BASE_URL=https://mcp.seehart.com/host
HOST_MCP_CLIENT_ID=host-mcp
HOST_MCP_CLIENT_SECRET=change-me
HOST_MCP_HOST=127.0.0.1
HOST_MCP_PORT=8754

# Default SSH target for deploy CLI (override per site in host.yaml)
HOST_SSH_USER=your-cpanel-user
HOST_SSH_HOST=seehart.com

# Bridge / gateway (also set on mcp-services VM)
# BRIDGE_MCP_CLIENT_SECRET=change-me
# CURSOR_API_KEY=...
